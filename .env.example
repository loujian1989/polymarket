# Copy this to .env and fill in your values
# Get your API key at: https://kalshi.com/account/profile -> API Keys

KALSHI_KEY_ID=your_key_id_here
KALSHI_PRIVATE_KEY_PATH=./kalshi_private.pem

# Optional: set your tier for correct rate limiting
# Options: basic, advanced, premier, paragon, prime
KALSHI_TIER=basic
